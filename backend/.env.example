# 服务器配置
HOST=127.0.0.1
PORT=8003

# MinerU API配置
MINERU_BASE_URL=https://mineru.net
MINERU_API_KEY=your_mineru_api_key_here

# 模型配置
BASE_URL=http://localhost:4000
API_KEY=your_api_key_here
EMBEDDING_MODEL=github_copilot/text-embedding-ada-002
DEFAULT_MODEL=gpt-4o

# LiteLLM 429 Fallback 配置
# 在 LiteLLM proxy 的 config.yaml 中配置 fallbacks，无需修改应用代码
# 示例：
#   model_list:
#     - model_name: gpt-4o
#       litellm_params:
#         model: gpt-4o
#     - model_name: gpt-4o              # 同名即 fallback
#       litellm_params:
#         model: gpt-4o-mini            # 备用模型
#   fallbacks:
#     - gpt-4o: ["gpt-4o-mini"]        # 主模型 429 时自动切换

# Milvus配置
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_DB_NAME=rag_test

# PostgreSQL配置
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password_here
POSTGRES_DB=rag_system

# Elasticsearch配置
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_USER=elastic
ELASTICSEARCH_PASSWORD=your_elasticsearch_password_here

# 日志配置
LOG_CONSOLE_LEVEL=20  # INFO级别
LOG_FILE_LEVEL=10  # DEBUG级别

# ── 追踪配置 ──────────────────────────────────────────────
# 追踪后端选择: phoenix | langfuse | none（默认关闭）
TRACER_BACKEND=none

# Phoenix 配置（TRACER_BACKEND=phoenix 时生效）
# 无需额外配置，Phoenix 本地运行
# 安装: pip install arize-phoenix openinference-instrumentation-langchain
# 启动后访问: http://localhost:6006

# Langfuse 配置（TRACER_BACKEND=langfuse 时生效）
# 自托管: docker run -p 3000:3000 langfuse/langfuse
# 或使用云服务: https://cloud.langfuse.com
# 安装: pip install langfuse
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
